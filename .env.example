# Firebase Web App (required for runtime)
VITE_FIREBASE_API_KEY=REPLACE_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=fleetpro-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=fleetpro-app
VITE_FIREBASE_STORAGE_BUCKET=fleetpro-app.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_FIREBASE_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=REPLACE_MEASUREMENT_ID

# Optional local dev helper
VITE_DEV_AUTO_LOGIN=false
