# ===== Firebase Web SDK Configuration (Required for Runtime) =====
# Get these values from: Firebase Console → Project Settings → General
# https://console.firebase.google.com/project/fleetpro-app/settings/general

# Web API Key (public, used by browser)
# Location: Firebase Console → Project Settings → General → Web API Key
VITE_FIREBASE_API_KEY=REPLACE_FIREBASE_API_KEY

# Authentication Domain
# Format: {PROJECT_ID}.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=fleetpro-app.firebaseapp.com

# Realtime Database URL (required for Firestore integration)
# Format: https://{PROJECT_ID}-default-rtdb.{REGION}.firebasedatabase.app
# Region examples: asia-southeast1, us-central1, europe-west1
VITE_FIREBASE_DATABASE_URL=https://fleetpro-app-default-rtdb.asia-southeast1.firebasedatabase.app

# Project ID
# Location: Firebase Console → Project Settings → General → Project ID
VITE_FIREBASE_PROJECT_ID=fleetpro-app

# Cloud Storage Bucket
# Format: {PROJECT_ID}.appspot.com
# Location: Firebase Console → Storage → Bucket Name
VITE_FIREBASE_STORAGE_BUCKET=fleetpro-app.firebasestorage.app

# Cloud Messaging Sender ID
# Location: Firebase Console → Project Settings → General → Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_MESSAGING_SENDER_ID

# Firebase App ID
# Location: Firebase Console → Project Settings → General → App ID
VITE_FIREBASE_APP_ID=REPLACE_FIREBASE_APP_ID

# Google Analytics Measurement ID (optional, for analytics)
# Location: Firebase Console → Project Settings → General → Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=REPLACE_MEASUREMENT_ID

# ===== Development Configuration =====
# Auto-login for development (local only, DO NOT commit)
VITE_DEV_AUTO_LOGIN=false

# ===== Driver Notification (Telegram only) =====
# Preferred in production: use server endpoint with secret env vars on Cloudflare.
# Frontend calls VITE_TELEGRAM_NOTIFY_ENDPOINT (default /api/notify/telegram).
VITE_TELEGRAM_NOTIFY_ENDPOINT=/api/notify/telegram

# Local/demo fallback: direct Telegram Bot API call from browser.
# WARNING: these values are exposed in frontend bundle. Use only for internal demo.
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# Optional support links (separate from dispatch notification channel)
VITE_CAL_EVENT_PATH=fleetpro-app/30min
VITE_SUPPORT_ZALO_GROUP=https://zalo.me/g/tdhmtu261
VITE_SUPPORT_ZALO_ADMIN=https://zalo.me/0989890022
VITE_SUPPORT_TELEGRAM=https://web.telegram.org/k/#-3799902499
VITE_SUPPORT_FACEBOOK_GROUP=https://www.facebook.com/groups/vibecodecoaching
VITE_SUPPORT_WHATSAPP_GROUP=https://chat.whatsapp.com/E2SNci7FscqCi3i4yCUt2W
