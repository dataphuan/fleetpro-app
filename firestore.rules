rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists() ? userDoc().data.role : 'viewer';
    }

    function tenantId() {
      return userDocExists() ? userDoc().data.tenant_id : 'none';
    }

    function canAccessTenantData() {
      return isAuthed() && userDocExists();
    }

    function sameTenantOnCreate() {
      return request.resource.data.tenant_id == tenantId() || isDemoTenant();
    }

    function sameTenantOnReadUpdateDelete() {
      return resource.data.tenant_id == tenantId();
    }

    function isTenantAdmin() {
      return userRole() == 'admin';
    }

    // QA AUDIT FIX: Demo tenant check uses ONLY tenant_id from Firestore user doc.
    // No email pattern matching — prevents unauthorized bypass via fake email domains.
    function isDemoTenant() {
      return userDocExists() && (
        userDoc().data.tenant_id == 'internal-tenant-1' || 
        userDoc().data.tenant_id == 'internal-tenant-phuan'
      );
    }

    // --- SECURE COLLECTION MATCHES ---

    // Users: Admin can manage, users can see self
    match /users/{uid} {
      allow read: if isAuthed() && (
        uid == request.auth.uid || 
        isDemoTenant() ||
        (canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin())
      );
      allow create: if isAuthed() && (
        // Registration (self-create user doc first time)
        uid == request.auth.uid ||
        // Admin inviting members
        (canAccessTenantData() && isTenantAdmin() && request.resource.data.tenant_id == tenantId())
      );
      allow update: if isAuthed() && (
        uid == request.auth.uid ||
        (canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin())
      );
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }

    // Company Settings: Admin Only + Self-Provisioning for New Registration
    match /company_settings/{tid} {
      allow read: if isAuthed() && (
        (canAccessTenantData() && tid == tenantId()) ||
        // Allow reading own company settings during registration flow
        (userDocExists() && userDoc().data.tenant_id == tid)
      );
      allow create: if isAuthed() && (
        // Normal admin create
        (canAccessTenantData() && tid == tenantId() && isTenantAdmin()) ||
        // Self-provisioning during registration
        (request.resource.data.admin_id == request.auth.uid) ||
        // Demo tenant seed bypass
        isDemoTenant()
      );
      // Updates: Admin-only. Internal/webhook updates must use Firebase Admin SDK (server-side).
      allow update: if canAccessTenantData() && tid == tenantId() && (isTenantAdmin() || isDemoTenant());
      allow delete: if false; // SaaS: Cannot delete your own tenant record from UI
    }

    // System Logs: Immutable Audit Trail
    match /system_logs/{logId} {
      allow read: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
      allow create: if isAuthed() && 
                    request.resource.data.user_id == request.auth.uid &&
                    request.resource.data.tenant_id == tenantId();
      allow update, delete: if false; // Immutable
    }

    // Tenants: Master collection — Secure tenant isolation
    match /tenants/{tid} {
      allow read: if isAuthed() && (
        (userDocExists() && userDoc().data.tenant_id == tid) ||
        (request.auth.token.tenant_id == tid)
      );
      allow create: if isAuthed() && canAccessTenantData() && tid == tenantId() && (isTenantAdmin() || isDemoTenant());
      allow update: if isAuthed() && canAccessTenantData() && tid == tenantId() && (isTenantAdmin() || isDemoTenant());
      allow delete: if false;
    }

    // ID Counters: Decentralized sequential ID generation
    // QA AUDIT FIX: Removed isDemoTenant bypass — demo tenants use same tenant prefix check
    match /counters/{counterId} {
      allow read, write: if isAuthed() && userDocExists() && 
        counterId.lower().matches('^' + userDoc().data.tenant_id.lower() + '.*');
    }

    // Trips: Secure tenant isolation + Driver data isolation
    match /trips/{tripId} {
      allow read: if isAuthed() && canAccessTenantData() && sameTenantOnReadUpdateDelete() && (
        userRole() != 'driver' || resource.data.driver_id == request.auth.uid || isDemoTenant()
      );
      allow create: if canAccessTenantData() && sameTenantOnCreate();
      allow update: if canAccessTenantData() && sameTenantOnReadUpdateDelete();
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }

    // Drivers: DATA ISOLATION — driver can only read own record
    match /drivers/{driverId} {
      allow read: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && (
        userRole() != 'driver' || isDemoTenant() || driverId == request.auth.uid
      );
      allow create, update: if canAccessTenantData() && (
        (userRole() == 'dispatcher' || userRole() == 'manager' || userRole() == 'admin')
      );
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }

    // QA AUDIT FIX: Explicit whitelist instead of catch-all wildcard.
    // Only known collections are accessible — prevents arbitrary collection creation.
    match /{collection}/{id} {
      function canWriteMasterData() {
        return userRole() in ['admin', 'manager', 'dispatcher', 'accountant'];
      }
      function canWriteFinancialData() {
        return userRole() in ['admin', 'manager', 'accountant'];
      }
      function canWriteOperationalData() {
        return userRole() in ['admin', 'manager', 'dispatcher'];
      }

      function isAllowedCollection() {
        return collection in [
          'vehicles', 'routes', 'customers', 'expenses',
          'maintenance', 'transportOrders', 'expenseCategories',
          'alerts', 'trip_location_logs', 'accountingPeriods', 'costs',
          'tires', 'inventory', 'inventoryTransactions', 'purchaseOrders', 'partners'
        ];
      }

      allow read: if isAllowedCollection()
                    && canAccessTenantData() && sameTenantOnReadUpdateDelete();
      
      allow create, update: if isAllowedCollection()
                    && canAccessTenantData() && (
                      isDemoTenant() ||
                      (collection in ['vehicles', 'routes', 'customers'] && sameTenantOnCreate() && canWriteMasterData()) ||
                      (collection == 'expenses' && canWriteFinancialData()) ||
                      (collection in ['maintenance', 'tires', 'inventory', 'inventoryTransactions', 'purchaseOrders', 'alerts', 'partners', 'transportOrders', 'expenseCategories', 'trip_location_logs', 'accountingPeriods', 'costs'] && (canWriteOperationalData() || canWriteFinancialData()))
                    );

      allow delete: if collection in ['vehicles', 'expenses', 'routes', 'customers']
                    && canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }
  }
}
