rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists() ? userDoc().data.role : 'viewer';
    }

    function tenantId() {
      return userDocExists() ? userDoc().data.tenant_id : 'none';
    }

    function canAccessTenantData() {
      return isAuthed() && userDocExists();
    }

    function sameTenantOnCreate() {
      return request.resource.data.tenant_id == tenantId() || isDemoTenant();
    }

    function sameTenantOnReadUpdateDelete() {
      return resource.data.tenant_id == tenantId();
    }

    function isTenantAdmin() {
      return userRole() == 'admin' || userRole() == 'admin_tenant';
    }

    function isDemoTenant() {
      // Robust check for demo tenant: either via user doc or if the user is a known demo email
      return (userDocExists() && userDoc().data.tenant_id == 'demo-tenant-tnc-001') || 
             (request.auth.token.email.matches('.*@demo\\.tnc\\.io\\.vn') || 
              request.auth.token.email.matches('.*@fleetpro\\.vn'));
    }

    // Unified check for demo mode reading
    function canReadDemoData(res) {
       return isDemoTenant() && res.data.tenant_id == 'demo-tenant-tnc-001';
    }

    // --- SECURE COLLECTION MATCHES ---

    // Users: Admin can manage, users can see self
    match /users/{uid} {
      allow read: if isAuthed() && (
        uid == request.auth.uid || 
        isDemoTenant() ||
        (canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin())
      );
      allow create: if isAuthed() && (
        // Registration (self-create user doc first time)
        uid == request.auth.uid ||
        // Admin inviting members
        (canAccessTenantData() && isTenantAdmin() && request.resource.data.tenant_id == tenantId())
      );
      allow update: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }

    // Company Settings: Admin Only
    match /company_settings/{tid} {
      allow read: if canAccessTenantData() && tid == tenantId();
      allow create, update: if canAccessTenantData() && tid == tenantId() && isTenantAdmin();
      allow delete: if false; // SaaS: Cannot delete your own tenant record from UI
    }

    // System Logs: Immutable Audit Trail
    match /system_logs/{logId} {
      allow read: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
      allow create: if isAuthed() && 
                    request.resource.data.user_id == request.auth.uid &&
                    request.resource.data.tenant_id == tenantId();
      allow update, delete: if false; // Immutable
    }

    // Tenants: Master collection — SERVER-SIDE ONLY (Cloud Functions / Admin SDK)
    // QA AUDIT FIX 1.1: No client-side writes to tenant records
    match /tenants/{tenantId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;
    }

    // Trips: SECURITY HARDENING — Server-side Writes Only + Driver Isolation
    match /trips/{tripId} {
      // DATA ISOLATION: Drivers can only read their own trips, EXCEPT in Demo mode
      allow read: if isAuthed() && (
        canReadDemoData(resource) ||
        (canAccessTenantData() && sameTenantOnReadUpdateDelete() && (
          userRole() != 'driver' || resource.data.driver_id == request.auth.uid
        ))
      );
      // Allow same-tenant creation from authenticated tenant user; updates allowed for QA fallback.
      allow create: if canAccessTenantData() && sameTenantOnCreate();
      allow update: if canAccessTenantData() && sameTenantOnReadUpdateDelete();
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();    }

    // Drivers: DATA ISOLATION — driver can only read own record
    match /drivers/{driverId} {
      allow read: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && (
        userRole() != 'driver' || isDemoTenant() || driverId == request.auth.uid
      );
      allow create, update: if canAccessTenantData() && (
        (collection in ['drivers'] && (userRole() == 'dispatcher' || userRole() == 'manager' || userRole() == 'admin'))
      );
      allow delete: if canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin();
    }

    // Role-based Access for other collections
    match /{collection}/{docId} {
      function canDispatcherWrite() {
        return userRole() == 'dispatcher' || userRole() == 'manager' || userRole() == 'admin';
      }
      function canAccountantWrite() {
        return userRole() == 'accountant' || userRole() == 'manager' || userRole() == 'admin';
      }
      function canManagerWrite() {
        return userRole() == 'manager' || userRole() == 'admin';
      }

      allow read: if !(collection in ['users', 'company_settings', 'system_logs', 'tenants', 'trips', 'drivers'])
                    && canAccessTenantData() && sameTenantOnReadUpdateDelete();
      
      // QA AUDIT FIX: Allow authenticated tenant users to create/update vehicles, drivers, routes, customers (not just dispatcher)
      allow create, update: if !(collection in ['users', 'company_settings', 'system_logs', 'tenants', 'trips', 'drivers'])
                    && canAccessTenantData() && (
                      (collection in ['vehicles', 'drivers', 'routes', 'customers'] && canAccessTenantData() && sameTenantOnCreate()) ||
                      (collection == 'expenses' && canAccountantWrite()) ||
                      (collection in ['maintenance', 'tires', 'inventory', 'inventoryTransactions', 'purchaseOrders', 'alerts', 'partners', 'transportOrders', 'expenseCategories', 'trip_location_logs'] && canManagerWrite())
                    );

      allow delete: if (collection in ['vehicles', 'drivers', 'expenses'])
                    ? (canAccessTenantData() && sameTenantOnReadUpdateDelete() && isTenantAdmin())
                    : false;
    }
  }
}
